generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  PERFORMER
  ADMIN
}

enum HelpType {
  LAB_GUIDANCE
  PRACTICE_COACHING
  REPORT_REVIEW
  COURSE_PROJECT_MENTORING
  THESIS_CONSULTING
}

enum MaterialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaterialType {
  NOTES
  TEMPLATE
  GUIDE
  PRESENTATION
  CHEATSHEET
  CODE_EXAMPLE
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  name              String
  university        String
  course            Int
  role              Role               @default(USER)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  performerProfile  PerformerProfile?
  uploadedMaterials StudyMaterial[]    @relation("AuthorMaterials")
  moderatedMaterials StudyMaterial[]   @relation("ModeratorMaterials")
  writtenReviews    PerformerReview[]  @relation("ReviewAuthor")
}

model PerformerProfile {
  id             String            @id @default(cuid())
  userId         String            @unique
  bio            String
  subjects       String[]
  startingPrices Json
  telegram       String?
  avatarUrl      String?
  isVerified     Boolean           @default(false)
  ratingAverage  Float             @default(0)
  ratingCount    Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews        PerformerReview[]

  @@index([isVerified, ratingAverage])
}

model PerformerReview {
  id          String           @id @default(cuid())
  performerId String
  authorId    String
  rating      Int
  comment     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  performer   PerformerProfile @relation(fields: [performerId], references: [id], onDelete: Cascade)
  author      User             @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([performerId, authorId])
  @@index([performerId, createdAt])
}

model StudyMaterial {
  id           String         @id @default(cuid())
  authorId     String
  moderatorId  String?
  title        String
  description  String
  subject      String
  university   String
  type         MaterialType
  status       MaterialStatus @default(PENDING)
  downloadUrl  String
  aiModeration Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  author       User           @relation("AuthorMaterials", fields: [authorId], references: [id], onDelete: Cascade)
  moderator    User?          @relation("ModeratorMaterials", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}
